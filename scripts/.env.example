# Meta Ads (get from developers.facebook.com)
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# Supabase (get from supabase.com > Project Settings > API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Shopify (get from Shopify Admin > Settings > Apps > Develop apps)
SHOPIFY_STORE_URL=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_your_token_here

# Amazon Ads (optional)
AMAZON_CLIENT_ID=
AMAZON_CLIENT_SECRET=
AMAZON_REFRESH_TOKEN=
AMAZON_PROFILE_ID=

# Flipkart Ads (optional)
FLIPKART_CLIENT_ID=
FLIPKART_CLIENT_SECRET=

# Google Analytics 4 (optional — H2S pilot)
#   GA4_PROPERTY_ID: numeric, from GA4 Admin > Property Settings
#   GA4_SERVICE_ACCOUNT_JSON: either a file path or the raw JSON of a service account key.
#   The service account email must be added as Viewer in GA4 Admin > Property Access Management.
GA4_PROPERTY_ID=
GA4_SERVICE_ACCOUNT_JSON=

# Google Search Console (optional — H2S pilot; reuses GA4 service account)
#   GSC_SITE_URL: domain property ('sc-domain:hard2soft.com') or URL prefix ('https://www.hard2soft.com/').
#   Add the service account email as a User in GSC > Settings > Users and permissions.
GSC_SITE_URL=

# Microsoft Clarity (optional — H2S pilot)
#   Dashboard > Settings > Data Export > Generate API token
CLARITY_PROJECT_ID=
CLARITY_API_TOKEN=

# GoKwik (optional — H2S pilot)
#   Issued by GoKwik merchant success team — no self-serve portal.
GOKWIK_API_KEY=
GOKWIK_MERCHANT_ID=
GOKWIK_API_BASE=https://api.gokwik.co

# Config
# How many days back each extractor pulls. Note: Shopify read_orders caps at 60
# days unless the app has the protected read_all_orders scope.
LOOKBACK_DAYS=60
